<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GÓC TIN HỌC SÁNG TẠO - CÔ HOÀNG MAI</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght=400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-shadow: none;
            box-sizing: border-box;
            font-family: 'Roboto', sans-serif;
        }

        body {
            background-color: #f1f5f9;
            color: #333333;
            padding: 20px 0;
        }

        .wrapper {
            max-width: 1200px;
            margin: 0 auto;
            background-color: #ffffff;
            border: 1px solid #cbd5e1;
        }

        .header-banner {
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            background-color: #ffffff;
            border-bottom: 1px solid #e2e8f0;
        }

        .header-banner i {
            font-size: 3rem;
            color: #b91c1c;
        }

        .header-text h1 {
            color: #b91c1c;
            font-size: 1.8rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .header-text p {
            color: #475569;
            font-size: 1rem;
            margin-top: 5px;
        }

        .main-nav {
            background-color: #b91c1c; 
        }

        .nav-list {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
        }

        .nav-list li a {
            display: block;
            padding: 12px 20px;
            color: #ffffff;
            text-decoration: none;
            font-weight: 500;
            font-size: 1rem;
            transition: background 0.2s;
            cursor: pointer;
        }

        .nav-list li a:hover, .nav-list li a.active {
            background-color: #991b1b; 
        }

        .main-container {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 20px;
            padding: 20px;
            background-color: #ffffff;
        }

        .sidebar {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .widget {
            border: 1px solid #b91c1c;
        }

        .widget-title {
            background-color: #b91c1c; 
            color: #ffffff;
            padding: 10px 15px;
            font-size: 1rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .widget-content {
            list-style: none;
        }

        .widget-content li {
            border-bottom: 1px solid #f1f5f9;
        }

        .widget-content li a {
            display: block;
            padding: 10px 15px;
            color: #333333;
            text-decoration: none;
            font-size: 0.95rem;
            cursor: pointer;
        }

        .widget-content li a:hover {
            background-color: #fef2f2;
            color: #b91c1c;
        }

        .content-area {
            border: 1px solid #e2e8f0;
            padding: 20px;
        }

        .content-title {
            color: #b91c1c;
            font-size: 1.4rem;
            font-weight: 700;
            text-transform: uppercase;
            border-bottom: 2px solid #b91c1c;
            padding-bottom: 8px;
            margin-bottom: 20px;
        }

        .teacher-info-box {
            display: grid;
            grid-template-columns: 1fr 350px;
            gap: 20px;
            align-items: start;
        }

        .info-text h2 {
            color: #b91c1c;
            font-size: 1.8rem;
            margin-bottom: 5px;
        }

        .info-text .role {
            color: #b91c1c;
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 15px;
        }

        .info-text .desc-box {
            border: 1px dashed #b91c1c;
            background-color: #fef2f2;
            padding: 15px;
            border-radius: 4px;
            line-height: 1.6;
            text-align: justify;
            color: #991b1b;
        }

        .info-image-container {
            border: 1px solid #e2e8f0;
            padding: 5px;
            background-color: #ffffff;
        }

        .info-image-container img {
            width: 100%;
            height: auto;
            display: block;
            object-fit: cover;
        }

        .kho-tai-lieu-container {
            display: none;
            margin-top: 15px;
        }

        .search-filter-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 20px;
            background: #f8fafc;
            padding: 15px;
            border-radius: 6px;
            border: 1px solid #e2e8f0;
        }

        .search-box-custom {
            flex: 1;
            min-width: 250px;
            position: relative;
        }

        .search-box-custom input {
            width: 100%;
            padding: 10px 12px 10px 35px;
            border: 1px solid #cbd5e1;
            border-radius: 4px;
            font-size: 0.95rem;
            outline: none;
        }

        .search-box-custom input:focus {
            border-color: #b91c1c;
        }

        .search-box-custom i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #64748b;
        }

        .filter-box-custom {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .filter-box-custom select {
            padding: 10px 12px;
            border: 1px solid #cbd5e1;
            border-radius: 4px;
            font-size: 0.95rem;
            background-color: #ffffff;
            outline: none;
            cursor: pointer;
        }

        .filter-box-custom select:focus {
            border-color: #b91c1c;
        }

        .documents-grid-custom {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .doc-card-custom {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-top: 4px solid #b91c1c;
            border-radius: 6px;
            padding: 15px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .doc-card-custom:hover {
            transform: translateY(-3px);
            box-shadow: 0 4px 12px rgba(0,0,0,0.
